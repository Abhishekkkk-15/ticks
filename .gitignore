# Python (backend)
backend/.venv/
**/__pycache__/
*.pyc
.env
!.env.example

# Node (frontend, safety net beyond frontend/.gitignore)
**/node_modules/

# OS
.DS_Store
Thumbs.db

# Local-first user data — never committed to the source repo
workspace/

# Local tool config
.claude/

# Claude Code /export transcripts (e.g. 2026-07-09-185754-some-slug.txt) —
# never belongs in the repo, just a local session dump.
/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-*.txt
