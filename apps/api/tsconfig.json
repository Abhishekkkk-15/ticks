{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@ticks/types": ["../../packages/types/src/index.ts"],
      "@ticks/types/*": ["../../packages/types/src/*"]
    }
  },
  "include": ["src/**/*", "../../packages/types/src/**/*"]
}
